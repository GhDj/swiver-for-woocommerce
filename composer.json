{
    "name": "ghdj/swiver-for-woocommerce",
    "description": "WooCommerce integration with Swiver invoicing platform",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Ghabri Djalel",
            "homepage": "https://github.com/GhDj"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "wp-phpunit/wp-phpunit": "^6.4",
        "yoast/phpunit-polyfills": "^2.0",
        "mockery/mockery": "^1.6",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "Swiver\\Swiver_WooCommerce\\": "inc/",
            "Swiver\\Swiver_WooCommerce\\Admin\\": "inc/admin/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Swiver\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
